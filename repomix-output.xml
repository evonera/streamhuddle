export const dodo = new DodoPayments(components.dodopayments, {
  // Maps our Convex Better Auth user to a Dodo Payments customer
  identify: async (ctx) => {
    const identity = await ctx.auth.getUserIdentity();
    if (!identity) {
      return null;
